# Database
# POSTGRES_PASSWORD is required by docker-compose (`:?` guard). `DATABASE_URL`
# is consumed by node apps and by the Python worker; keep the password in both
# values identical for host-local dev. For prod deployments pick a long random
# string — no default password is committed.
POSTGRES_DB=opencairn
POSTGRES_USER=opencairn
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://opencairn:SET_POSTGRES_PASSWORD@localhost:5432/opencairn
# Compose publishes Postgres to loopback only by default (S3-052 / CLAUDE.md
# Security § "PostgreSQL not exposed to internet"). Set POSTGRES_HOST_BIND=0.0.0.0
# only behind a network ACL with a strong password.
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432

# Docker Compose app containers use service DNS instead of host-local
# localhost URLs. Leave these unset unless you need to point compose at an
# external managed service.
COMPOSE_DATABASE_URL=
# If REDIS_PASSWORD is set below, include it here too:
# COMPOSE_REDIS_URL=redis://:SET_REDIS_PASSWORD@redis:6379
COMPOSE_REDIS_URL=redis://redis:6379
COMPOSE_TEMPORAL_ADDRESS=temporal:7233
COMPOSE_INTERNAL_API_URL=http://api:4000
COMPOSE_S3_ENDPOINT=minio:9000

# Redis — used for ingest event pub/sub and (future) rate limiting / locks.
# Compose publishes Redis to loopback only by default. To expose beyond the
# local host, set REDIS_HOST_BIND=0.0.0.0 and require REDIS_PASSWORD, then put
# the password into REDIS_URL and COMPOSE_REDIS_URL.
REDIS_HOST_BIND=127.0.0.1
REDIS_HOST_PORT=6379
REDIS_PASSWORD=
# If REDIS_PASSWORD is set:
# REDIS_URL=redis://:SET_REDIS_PASSWORD@localhost:6379
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000
WEB_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── LLM Provider ───────────────────────────────────────────────────────────
# packages/llm factory reads these. "gemini" | "ollama"  (openai는 2026-04-15 제거).
LLM_PROVIDER=gemini

# Gemini (production default)
LLM_API_KEY=
LLM_MODEL=gemini-3-flash-preview
# Embedding model — gemini-embedding-001 (MTEB multilingual #1, Batch API 50% off).
# Native 3072d with Matryoshka truncation down to VECTOR_DIM below. ADR-007.
EMBED_MODEL=gemini-embedding-001
TTS_MODEL=gemini-2.5-flash-preview-tts

# Back-compat alias used by code paths that still read GEMINI_API_KEY directly.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ── Chat surface (apps/api/src/lib/chat-llm.ts) ─────────────────────────────
# The chat path uses @google/genai TS SDK directly (not packages/llm).
# Reuses GEMINI_API_KEY above. Override GEMINI_CHAT_MODEL if you need a
# different chat-tier model than the worker uses.
GEMINI_CHAT_MODEL=gemini-2.5-flash

# RAG retrieval bounds (apps/api/src/lib/chat-retrieval.ts).
# top_k 5 / 12 covers typical ingest sizes; raise CHAT_RAG_MAX_PROJECTS
# if a workspace contains many projects and workspace-wide RAG feels under-
# inclusive.
CHAT_RAG_TOP_K_STRICT=5
CHAT_RAG_TOP_K_EXPAND=12
CHAT_RAG_MAX_PROJECTS=64
# Workspace-scope fanout caps simultaneous projectHybridSearch calls so the
# per-project vector + bm25 queries don't exhaust the postgres-js pool
# (default 10) under load. Each project costs 2 concurrent DB queries.
CHAT_RAG_FANOUT_CONCURRENCY=8

# History truncation (apps/api/src/lib/chat-llm.ts).
CHAT_MAX_HISTORY_TURNS=12
CHAT_MAX_INPUT_TOKENS=32000
CHAT_MAX_OUTPUT_TOKENS=2048

# Ollama — fully local (LLM_PROVIDER=ollama 일 때)
# LLM_API_KEY=                    # (비워둠)
# LLM_MODEL=llama3
# EMBED_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://ollama:11434   # docker compose 내부, 호스트에서는 http://localhost:11434
# Compose publishes Ollama to loopback only by default (S3-052). Ollama has
# no auth; override only behind a reverse proxy that adds it.
OLLAMA_HOST_BIND=127.0.0.1
OLLAMA_HOST_PORT=11434

# Embedding dimension — packages/db custom-types.ts와 packages/llm 임베딩 모델이 함께 사용.
# 768  = Gemini gemini-embedding-001 Matryoshka truncate (default, MTEB 품질 손실 ~0.26%)
# 1536 = 중간 절충 (MTEB 거의 동일)
# 3072 = Gemini 001 native (저장 4배)
# 768  = Ollama nomic-embed-text 호환
# 변경 시 DB 마이그레이션 재생성 + 기존 embedding NULL 처리 필요 (ADR-007 참조).
VECTOR_DIM=768

# Storage — 로컬 개발은 MinIO (docker-compose), 프로덕션은 Cloudflare R2 등 S3 호환.
# S3_ENDPOINT는 "host:port" 또는 "http(s)://host:port" 모두 허용. s3.ts가 파싱.
MINIO_ROOT_USER=opencairn-minio
# Optional override for the MinIO root password. If unset, compose reuses
# S3_SECRET_KEY for the local MinIO service.
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=opencairn-minio
# Required for compose MinIO and for app/worker S3 clients.
S3_SECRET_KEY=
S3_BUCKET=opencairn-uploads
S3_USE_SSL=false
# Compose publishes both the S3 endpoint (9000) and the console (9001) on
# loopback only by default (S3-052). Override only behind a reverse proxy
# with rotated credentials.
MINIO_HOST_BIND=127.0.0.1
MINIO_HOST_PORT_S3=9000
MINIO_HOST_PORT_CONSOLE=9001

# Temporal (Plan 3 Task 2에서 docker compose service 추가 예정)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ingest
# Host port mapping for the `temporal` compose service. Default 7233 works on
# Linux/Mac. On Windows + Hyper-V/WSL, ports 7147-7246 may be excluded — set
# both vars together (e.g. TEMPORAL_HOST_PORT=17233 +
# TEMPORAL_ADDRESS=localhost:17233) so host clients hit the remapped port.
TEMPORAL_HOST_PORT=7233
# Compose publishes Temporal gRPC + UI to loopback only by default (S3-052).
# Single-node Temporal ships without auth in this configuration; use SSH
# tunnel or a reverse proxy with mTLS/auth before flipping to 0.0.0.0.
TEMPORAL_HOST_BIND=127.0.0.1
TEMPORAL_UI_HOST_BIND=127.0.0.1
TEMPORAL_UI_HOST_PORT=8080

# ── Batch embedding (Plan 3b) ──────────────────────────────────────────────
# Gemini async batch embed — 50% discount vs. synchronous `embed_content`
# (ADR-007 pricing table). Gated per-agent because Compiler and Librarian
# have very different latency budgets: Librarian is an overnight sweep, so
# the "up to 24h" batch SLA is fine; Compiler runs during ingest so any
# hours-long delay blocks new-note hybrid-search.
#
# Default false on both. Flip Librarian ON first, observe cost + p95, then
# decide on Compiler. All caller paths fall through to synchronous embed
# silently when flags are off or the provider doesn't support batch (Ollama).
# Enabling: `BATCH_EMBED_{COMPILER,LIBRARIAN}_ENABLED=true` then RESTART
# worker containers. The caller-side activity timeout is derived at module
# import via `worker/lib/batch_timeouts.py`; an env flip without a restart
# is a no-op until the next boot. Structured events at `event=batch_embed.*`
# (ops.md) give visibility; the binary flag + silent sync fallback is the
# kill switch. Full runbook: `docs/contributing/ops.md` § Batch Embeddings.
BATCH_EMBED_COMPILER_ENABLED=false
BATCH_EMBED_LIBRARIAN_ENABLED=false
# Minimum items per batch — below this, the batch tier's savings don't
# justify the hours-of-latency cost, so embed_many falls through to sync.
BATCH_EMBED_MIN_ITEMS=8
# Caller-side split ceiling — batches bigger than this are chunked in
# `worker/lib/batch_submit.py` so each chunk fits under Gemini's
# InlinedRequests quota and the JSONL sidecar stays well under the
# Temporal 2 MiB payload cap.
BATCH_EMBED_MAX_ITEMS=2000
# Poll cadence & ceiling. Initial interval doubles up to the cap between
# polls; total wait is bounded so stuck batches don't hang a workflow
# forever. 24h = documented Gemini SLA.
BATCH_EMBED_INITIAL_POLL_SECONDS=60
BATCH_EMBED_MAX_POLL_SECONDS=1800
BATCH_EMBED_MAX_WAIT_SECONDS=86400
# JSONL sidecar retention for the `scripts/purge_embedding_jsonl.py` cron.
# R2 production uses a bucket lifecycle rule instead — see ops.md.
BATCH_EMBED_JSONL_TTL_DAYS=7

# Upload limits (Plan 3)
MAX_UPLOAD_BYTES=209715200         # 200 MB 기본
MAX_IMAGE_BYTES=20971520           # 20 MB
MAX_AUDIO_VIDEO_BYTES=524288000    # 500 MB
INGEST_QUARANTINE_PREFIX=quarantine/

# Internal API secret (worker → API callbacks)
INTERNAL_API_SECRET=

# Billing (provider-agnostic)
# 결제 레일 (Toss Payments 예정)은 사업자등록 후 결정. 현재 BLOCKED — billing-model.md 참조.
# 로컬 개발에서는 BILLING_ENABLED=false 유지.
BILLING_ENABLED=false

# ── Email ──────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER: "resend" | "smtp" | "console"
#   - resend  → Resend HTTP API (set RESEND_API_KEY below)
#   - smtp    → nodemailer / SMTP (set SMTP_HOST/PORT/USER/PASS below)
#   - console → log emails to stdout, never deliver (dev fallback)
# Unset → auto-detect: RESEND_API_KEY wins, then SMTP_HOST, else console in
# development. In NODE_ENV=production, unset delivery fails closed; set
# EMAIL_PROVIDER=console explicitly only for log-only production installs.
# Used by signup/email-verification + password-reset + workspace invite flows.
EMAIL_PROVIDER=
EMAIL_FROM=OpenCairn <noreply@example.com>
# Public base URL of the web app — used to build invite/verify/reset links.
WEB_BASE_URL=http://localhost:3000

# Resend (when EMAIL_PROVIDER=resend or auto)
RESEND_API_KEY=

# SMTP (when EMAIL_PROVIDER=smtp). Self-hosted Postfix, Mailgun SMTP, AWS SES
# SMTP, etc. Port 465 → implicit TLS; everything else → STARTTLS upgrade.
# Override with SMTP_SECURE=true|false for non-standard ports (e.g., 2525).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=

# Plan 2 Task 14 — outbound notification email loop.
# Set to "true" once EMAIL_PROVIDER and either RESEND_API_KEY or SMTP_HOST
# are configured. The dispatcher checks the notifications table every 60s
# inside apps/api, sends per-kind emails for instant rows, and groups
# digest_15min / digest_daily rows into one DigestEmail per kind. Default
# OFF so self-hosters without an SMTP/Resend setup never see send errors.
EMAIL_DISPATCHER_ENABLED=false

# ── Observability (Sentry) ─────────────────────────────────────────────────
# Optional. Leave SENTRY_DSN empty to disable error reporting entirely
# (no-op init, no network calls). When set, errors caught by the Hono
# onError handler get forwarded with environment + release tags.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Sample 10% of traces by default — enough for diagnosis without burning a
# free-tier quota on a steady-traffic self-hosted instance.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Comma-separated list of allowed web origins (used for both CORS and Better Auth trustedOrigins)
CORS_ORIGIN=http://localhost:3000

# 웹→API 내부 통신 URL (Docker 환경에서는 컨테이너 이름)
INTERNAL_API_URL=http://localhost:4000
# Docker Compose 환경:
# INTERNAL_API_URL=http://api:4000
# `docker compose --profile worker` (api still on host):
# INTERNAL_API_URL=http://host.docker.internal:4000

# Agent runtime — where the worker lands per-run NDJSON trajectories
# (Plan 12 LocalFSTrajectoryStorage). In the containerised worker this is
# backed by the worker_trajectories volume.
TRAJECTORY_DIR=/var/opencairn/trajectories

# Per-project semaphore (Plan 4 Task 8). Caps concurrent Compiler/Research
# runs per project — Librarian runs outside the semaphore in v0.
SEMAPHORE_MAX_CONCURRENT=3
SEMAPHORE_TTL_SECONDS=1800
SEMAPHORE_POLL_SECONDS=1.5

# ── Hocuspocus (Yjs WS) — Plan 2B ──────────────────────────────────────────
# URL apps/web uses for the collaboration socket. Dev: localhost. Prod: your
# deployment's WSS endpoint. Same value is exposed to the browser via
# NEXT_PUBLIC_HOCUSPOCUS_URL — Next.js inlines NEXT_PUBLIC_* at build time.
HOCUSPOCUS_URL=ws://localhost:1234
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
# Comma-separated list of allowed WebSocket Origin headers. Matches the
# web app's public origin(s). CORS for the HTTP upgrade handshake.
HOCUSPOCUS_ORIGINS=http://localhost:3000

# ── Live Ingest Visualization ──────────────────────────────────────────────
# Mounts the spotlight + dock UI overlays in the AppShell. Backend always
# publishes IngestEvents to Redis (Tasks 3-7), so flipping this flag is
# UI-only — zero risk of backend regression on disable.
NEXT_PUBLIC_FEATURE_LIVE_INGEST=true
# Replay LIST trim + TTL — bound the per-workflow event ring buffer in Redis.
INGEST_REPLAY_TTL_SECONDS=3600
INGEST_REPLAY_MAX_LEN=1000

# ── Canvas / Code Agent ────────────────────────────────────────────────────
# FEATURE_CODE_AGENT must be enabled on both API and worker after the worker
# registers CodeAgentWorkflow. Keep off for default self-host installs unless
# LLM credentials and Temporal worker capacity are ready.
FEATURE_CODE_AGENT=false
FEATURE_CANVAS_TEMPLATES=false
FEATURE_CANVAS_OUTPUT_STORE=true

# ── Doc Editor slash commands (Plan 11B Phase A) ───────────────────────────
# Server flag gates the API + worker workflow registration. NEXT_PUBLIC flag
# gates the browser menu and is baked into the web image at build time.
# Default ON (audit H5, 2026-04-30): the four LLM commands ship enabled so the
# slash menu surfaces them out of the box. Set both to false on hosts without
# a Gemini key or worker capacity to fall back to block-only commands + 404.
FEATURE_DOC_EDITOR_SLASH=true
NEXT_PUBLIC_FEATURE_DOC_EDITOR_SLASH=true

# ── MCP Client ───────────────────────────────────────────────────────────
# Default OFF. API routes return 404 and worker MCP resolution short-circuits
# unless this is explicitly enabled.
FEATURE_MCP_CLIENT=false
# Optional host regex. Empty means any HTTPS public host that passes SSRF guard.
MCP_URL_ALLOWLIST=

# ── Content-aware enrichment ───────────────────────────────────────────────
# Worker-only ingest enrichment splice. Off by default because it adds LLM
# calls to ingest.
FEATURE_CONTENT_ENRICHMENT=false

# ── Ingest Source Expansion — /import (Drive + Notion) ─────────────────────
# Feature flag gating the /app/w/[slug]/import route and its sub-routes.
# Defaults on; set to "false" to hide the UI during hosted rollout control.
FEATURE_IMPORT_ENABLED=true

# Google OAuth 2.0 client for the Drive import path. Register in Google Cloud
# Console → APIs & Services → Credentials. Application type: Web. Authorized
# redirect URI: {PUBLIC_API_URL}/api/integrations/google/callback. Requested
# scopes (non-sensitive, no CASA audit needed): drive.file, userinfo.email.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Base URL the callback redirects back to. Must exactly match one of the
# "Authorized redirect URIs" on the OAuth client. Falls back to BETTER_AUTH_URL
# / localhost:4000 in apps/api/src/routes/integrations.ts so dev works without
# extra config, but production should set this explicitly.
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public site / SEO. Legal, blog, and marketing analytics are hosted outside
# the OSS app by default; point these URLs at the hosted marketing site when
# running the managed service. Leave analytics IDs empty until snippets are
# explicitly wired.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LEGAL_PRIVACY_URL=
NEXT_PUBLIC_LEGAL_TERMS_URL=
NEXT_PUBLIC_LEGAL_REFUND_URL=
NEXT_PUBLIC_BLOG_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# 32-byte base64 key for AES-256-GCM encryption of stored OAuth tokens.
# Generate with: `openssl rand -base64 32`. The same key decrypts on the
# worker side via apps/worker/src/worker/lib/integration_crypto.py.
#
# Rotation: copy the previous key into INTEGRATION_TOKEN_ENCRYPTION_KEY_OLD
# before swapping the current key. Decrypt tries current → _OLD; encrypt
# always uses current. Drop _OLD only after every existing token has been
# migrated (background re-encrypt or natural expiry). See
# docs/contributing/byok-key-rotation.md.
INTEGRATION_TOKEN_ENCRYPTION_KEY=
INTEGRATION_TOKEN_ENCRYPTION_KEY_OLD=

# Literature search/import. Semantic Scholar works without a key at lower
# quota; Unpaywall asks for an operator contact email.
SEMANTIC_SCHOLAR_API_KEY=
UNPAYWALL_EMAIL=

# Notion ZIP size ceilings. The API enforces these against the presigned
# upload endpoint (MAX_BYTES) and the worker enforces the uncompressed total
# inside unzip_and_walk defenses. 5 GB compressed / 20 GB uncompressed is
# generous enough for even the largest Notion workspace exports seen in the
# wild (2024).
IMPORT_NOTION_ZIP_MAX_BYTES=5368709120
IMPORT_NOTION_ZIP_MAX_UNCOMPRESSED_BYTES=21474836480

# Where the worker stages unzipped Notion exports. Must be a path the worker
# process can write to AND read from during the per-file convert pass. In
# docker-compose this lives under a named volume; local dev may prefer a tmp
# path so staged files get swept on reboot.
NOTION_IMPORT_STAGING_DIR=/var/opencairn/import-staging

# ── Deep Research — Spec 2026-04-22-deep-research-integration-design ────────
# Master toggle. Defaults on; set to "false" to hide /api/research,
# /app/w/[slug]/research, and the Temporal workflow/activity registration.
FEATURE_DEEP_RESEARCH=true
# Managed PAYG path. Off → only billingPath=byok is accepted; the worker
# returns status=failed, error.code=managed_disabled for any managed run.
# Flip after Plan 9b (billing engine) lands.
FEATURE_MANAGED_DEEP_RESEARCH=false
# Server account key used when billingPath=managed. Loaded regardless of the
# managed flag so the worker fails closed instead of silently when the flag
# is on but the key is missing.
GEMINI_MANAGED_API_KEY=
# Managed path margin. Cost estimate * MANAGED_MARGIN = user charge.
# Default 1.3 per spec §7.4. Only consulted on managed runs.
MANAGED_MARGIN=1.3

# ── Synthesis Export Pro tier (Plan: 2026-04-27-multi-format-synthesis-export) ──
# Master toggle for the LaTeX→PDF Tectonic MSA. Off by default so default
# self-host installs don't pull the ~1GB tectonic image. Flip to enable
# `docker compose --profile pro up tectonic` and the worker's PDF compile path.
FEATURE_SYNTHESIS_EXPORT=false
FEATURE_TECTONIC_COMPILE=false
TECTONIC_URL=http://tectonic:8888
TECTONIC_TIMEOUT_S=120
