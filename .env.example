# Database
# POSTGRES_PASSWORD is required by docker-compose (`:?` guard). `DATABASE_URL`
# is consumed by node apps and by the Python worker; keep the password in both
# values identical. For prod deployments pick a long random string — the old
# `changeme` default is rejected at compose parse time.
POSTGRES_DB=opencairn
POSTGRES_USER=opencairn
POSTGRES_PASSWORD=changeme-dev-only
DATABASE_URL=postgresql://opencairn:changeme-dev-only@localhost:5432/opencairn

# Redis
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=change-me-to-random-32-chars
BETTER_AUTH_URL=http://localhost:4000

# ── LLM Provider ───────────────────────────────────────────────────────────
# packages/llm factory reads these. "gemini" | "ollama"  (openai는 2026-04-15 제거).
LLM_PROVIDER=gemini

# Gemini (production default)
LLM_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-3-flash-preview
# Embedding model — gemini-embedding-001 (MTEB multilingual #1, Batch API 50% off).
# Native 3072d with Matryoshka truncation down to VECTOR_DIM below. ADR-007.
EMBED_MODEL=gemini-embedding-001
TTS_MODEL=gemini-2.5-flash-preview-tts

# Back-compat alias used by code paths that still read GEMINI_API_KEY directly.
GEMINI_API_KEY=your-gemini-api-key

# Ollama — fully local (LLM_PROVIDER=ollama 일 때)
# LLM_API_KEY=                    # (비워둠)
# LLM_MODEL=llama3
# EMBED_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://ollama:11434   # docker compose 내부, 호스트에서는 http://localhost:11434

# Embedding dimension — packages/db custom-types.ts와 packages/llm 임베딩 모델이 함께 사용.
# 768  = Gemini gemini-embedding-001 Matryoshka truncate (default, MTEB 품질 손실 ~0.26%)
# 1536 = 중간 절충 (MTEB 거의 동일)
# 3072 = Gemini 001 native (저장 4배)
# 768  = Ollama nomic-embed-text 호환
# 변경 시 DB 마이그레이션 재생성 + 기존 embedding NULL 처리 필요 (ADR-007 참조).
VECTOR_DIM=768

# Storage — 로컬 개발은 MinIO (docker-compose), 프로덕션은 Cloudflare R2 등 S3 호환.
# S3_ENDPOINT는 "host:port" 또는 "http(s)://host:port" 모두 허용. s3.ts가 파싱.
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=opencairn-uploads
S3_USE_SSL=false

# Temporal (Plan 3 Task 2에서 docker compose service 추가 예정)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ingest
# Host port mapping for the `temporal` compose service. Default 7233 works on
# Linux/Mac. On Windows + Hyper-V/WSL, ports 7147-7246 may be excluded — set
# both vars together (e.g. TEMPORAL_HOST_PORT=17233 +
# TEMPORAL_ADDRESS=localhost:17233) so host clients hit the remapped port.
TEMPORAL_HOST_PORT=7233

# ── Batch embedding (Plan 3b) ──────────────────────────────────────────────
# Gemini async batch embed — 50% discount vs. synchronous `embed_content`
# (ADR-007 pricing table). Gated per-agent because Compiler and Librarian
# have very different latency budgets: Librarian is an overnight sweep, so
# the "up to 24h" batch SLA is fine; Compiler runs during ingest so any
# hours-long delay blocks new-note hybrid-search.
#
# Default false on both. Flip Librarian ON first, observe cost + p95, then
# decide on Compiler. All caller paths fall through to synchronous embed
# silently when flags are off or the provider doesn't support batch (Ollama).
# Enabling: `BATCH_EMBED_{COMPILER,LIBRARIAN}_ENABLED=true` then RESTART
# worker containers. The caller-side activity timeout is derived at module
# import via `worker/lib/batch_timeouts.py`; an env flip without a restart
# is a no-op until the next boot. Structured events at `event=batch_embed.*`
# (ops.md) give visibility; the binary flag + silent sync fallback is the
# kill switch. Full runbook: `docs/contributing/ops.md` § Batch Embeddings.
BATCH_EMBED_COMPILER_ENABLED=false
BATCH_EMBED_LIBRARIAN_ENABLED=false
# Minimum items per batch — below this, the batch tier's savings don't
# justify the hours-of-latency cost, so embed_many falls through to sync.
BATCH_EMBED_MIN_ITEMS=8
# Caller-side split ceiling — batches bigger than this are chunked in
# `worker/lib/batch_submit.py` so each chunk fits under Gemini's
# InlinedRequests quota and the JSONL sidecar stays well under the
# Temporal 2 MiB payload cap.
BATCH_EMBED_MAX_ITEMS=2000
# Poll cadence & ceiling. Initial interval doubles up to the cap between
# polls; total wait is bounded so stuck batches don't hang a workflow
# forever. 24h = documented Gemini SLA.
BATCH_EMBED_INITIAL_POLL_SECONDS=60
BATCH_EMBED_MAX_POLL_SECONDS=1800
BATCH_EMBED_MAX_WAIT_SECONDS=86400
# JSONL sidecar retention for the `scripts/purge_embedding_jsonl.py` cron.
# R2 production uses a bucket lifecycle rule instead — see ops.md.
BATCH_EMBED_JSONL_TTL_DAYS=7

# Upload limits (Plan 3)
MAX_UPLOAD_BYTES=209715200         # 200 MB 기본
MAX_IMAGE_BYTES=20971520           # 20 MB
MAX_AUDIO_VIDEO_BYTES=524288000    # 500 MB
INGEST_QUARANTINE_PREFIX=quarantine/

# Internal API secret (worker → API callbacks)
INTERNAL_API_SECRET=change-me-in-production

# Billing (provider-agnostic)
# 결제 레일 (Toss Payments 예정)은 사업자등록 후 결정. 현재 BLOCKED — billing-model.md 참조.
# 로컬 개발에서는 BILLING_ENABLED=false 유지.
BILLING_ENABLED=false

# Email (Resend) — leave unset to log to console in dev
RESEND_API_KEY=
EMAIL_FROM=OpenCairn <hello@opencairn.com>
# Public base URL of the web app — used to build invite links in outgoing emails.
WEB_BASE_URL=http://localhost:3000

# Comma-separated list of allowed web origins (used for both CORS and Better Auth trustedOrigins)
CORS_ORIGIN=http://localhost:3000

# 웹→API 내부 통신 URL (Docker 환경에서는 컨테이너 이름)
INTERNAL_API_URL=http://localhost:4000
# Docker Compose 환경:
# INTERNAL_API_URL=http://api:4000
# `docker compose --profile worker` (api still on host):
# INTERNAL_API_URL=http://host.docker.internal:4000

# Agent runtime — where the worker lands per-run NDJSON trajectories
# (Plan 12 LocalFSTrajectoryStorage). In the containerised worker this is
# backed by the worker_trajectories volume.
TRAJECTORY_DIR=/var/opencairn/trajectories

# Per-project semaphore (Plan 4 Task 8). Caps concurrent Compiler/Research
# runs per project — Librarian runs outside the semaphore in v0.
SEMAPHORE_MAX_CONCURRENT=3
SEMAPHORE_TTL_SECONDS=1800
SEMAPHORE_POLL_SECONDS=1.5

# ── Hocuspocus (Yjs WS) — Plan 2B ──────────────────────────────────────────
# URL apps/web uses for the collaboration socket. Dev: localhost. Prod: your
# deployment's WSS endpoint. Same value is exposed to the browser via
# NEXT_PUBLIC_HOCUSPOCUS_URL — Next.js inlines NEXT_PUBLIC_* at build time.
HOCUSPOCUS_URL=ws://localhost:1234
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
# Comma-separated list of allowed WebSocket Origin headers. Matches the
# web app's public origin(s). CORS for the HTTP upgrade handshake.
HOCUSPOCUS_ORIGINS=http://localhost:3000

# ── Ingest Source Expansion — /import (Drive + Notion) ─────────────────────
# Feature flag gating the /app/w/[slug]/import route and its sub-routes. Set
# to "true" to expose the UI; anything else (including unset) returns 404.
FEATURE_IMPORT_ENABLED=false

# Google OAuth 2.0 client for the Drive import path. Register in Google Cloud
# Console → APIs & Services → Credentials. Application type: Web. Authorized
# redirect URI: {PUBLIC_API_URL}/api/integrations/google/callback. Requested
# scopes (non-sensitive, no CASA audit needed): drive.file, userinfo.email.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Base URL the callback redirects back to. Must exactly match one of the
# "Authorized redirect URIs" on the OAuth client. Falls back to BETTER_AUTH_URL
# / localhost:4000 in apps/api/src/routes/integrations.ts so dev works without
# extra config, but production should set this explicitly.
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000

# 32-byte base64 key for AES-256-GCM encryption of stored OAuth tokens.
# Generate with: `openssl rand -base64 32`. The same key decrypts on the worker
# side via apps/worker/src/worker/lib/integration_crypto.py — do NOT rotate
# without re-encrypting the user_integrations rows.
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# Notion ZIP size ceilings. The API enforces these against the presigned
# upload endpoint (MAX_BYTES) and the worker enforces the uncompressed total
# inside unzip_and_walk defenses. 5 GB compressed / 20 GB uncompressed is
# generous enough for even the largest Notion workspace exports seen in the
# wild (2024).
IMPORT_NOTION_ZIP_MAX_BYTES=5368709120
IMPORT_NOTION_ZIP_MAX_UNCOMPRESSED_BYTES=21474836480

# Where the worker stages unzipped Notion exports. Must be a path the worker
# process can write to AND read from during the per-file convert pass. In
# docker-compose this lives under a named volume; local dev may prefer a tmp
# path so staged files get swept on reboot.
NOTION_IMPORT_STAGING_DIR=/var/opencairn/import-staging

# ── Deep Research — Spec 2026-04-22-deep-research-integration-design ────────
# Master toggle. Off → /api/research, /app/w/[slug]/research, and the Temporal
# workflow/activity registration all no-op. Turn on after Phase C+D ships.
FEATURE_DEEP_RESEARCH=false
# Managed PAYG path. Off → only billingPath=byok is accepted; the worker
# returns status=failed, error.code=managed_disabled for any managed run.
# Flip after Plan 9b (billing engine) lands.
FEATURE_MANAGED_DEEP_RESEARCH=false
# Server account key used when billingPath=managed. Loaded regardless of the
# managed flag so the worker fails closed instead of silently when the flag
# is on but the key is missing.
GEMINI_MANAGED_API_KEY=
# Managed path margin. Cost estimate * MANAGED_MARGIN = user charge.
# Default 1.3 per spec §7.4. Only consulted on managed runs.
MANAGED_MARGIN=1.3
