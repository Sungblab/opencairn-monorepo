# apps/api environment overlay.
#
# The bulk of the API's runtime config (DATABASE_URL, S3_*, BETTER_AUTH_*,
# RESEND_*, INTERNAL_API_SECRET, …) lives in the repo-root `.env.example`
# because the same values are shared with the worker, hocuspocus, and the
# Next.js web app. This file documents flags that are API-process-specific
# so a deployer can set them in an api-only secret manager without grepping
# the root file.

# ── Plan 7 Phase 2 — Code Agent + Canvas ──────────────────────────────────
# Master toggle for /api/code/* (run / feedback / SSE stream). Off → every
# public code endpoint 404s; the internal worker callbacks under
# /api/internal/code/* keep working so a mid-flight workflow can still
# checkpoint. Flip after the worker has registered CodeAgentWorkflow.
FEATURE_CODE_AGENT=false

# /api/canvas/from-template feature gate. Plan 6 (templates) will swap the
# 501 stub for the real instantiation workflow. Off by default until then.
# When on, the route still returns 501 templatesNotAvailable in Phase 2 —
# the flag exists so Plan 6 can flip it without touching this file.
FEATURE_CANVAS_TEMPLATES=false

# Persist matplotlib / SVG outputs under canvas-outputs/{ws}/{note}/{hash}.{ext}
# in MinIO. Default ON — the canvas viewer relies on the listing endpoint to
# render previous artifacts. Flip OFF only as an incident-response cost knob;
# in-flight uploads will 404 silently while flipped, no data is dropped.
FEATURE_CANVAS_OUTPUT_STORE=true
