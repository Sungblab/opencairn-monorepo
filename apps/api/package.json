{
  "name": "@opencairn/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./public": "./src/public.ts",
    "./note-chunk-refresh": "./src/lib/note-chunk-refresh.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/index.js",
    "benchmark:rag-agent": "tsx scripts/rag-agent-benchmark.ts",
    "benchmark:rag-db": "tsx scripts/rag-db-retrieval-benchmark.ts",
    "smoke:code-preview": "node scripts/code-preview-browser-smoke.mjs",
    "smoke:live-product-flow": "tsx scripts/live-product-flow-smoke.ts",
    "smoke:live-product-cleanup": "tsx scripts/cleanup-live-product-flow-smoke.ts",
    "test": "vitest run",
    "test:eval": "vitest run --config vitest.eval.config.ts tests/lib/answer-verifier.eval.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@hono/node-server": "^2.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "1",
    "@opencairn/db": "workspace:*",
    "@opencairn/emails": "workspace:*",
    "@opencairn/shared": "workspace:*",
    "@slate-yjs/core": "^1.0.2",
    "@react-email/render": "^2.0.8",
    "@sentry/node": "^10.51.0",
    "@temporalio/client": "^1.17.0",
    "better-auth": "^1.6.9",
    "docx": "^9.6.1",
    "hono": "^4.12.16",
    "ioredis": "^5.6.0",
    "minio": "^8.0.7",
    "nodemailer": "^8.0.7",
    "playwright": "^1.59.1",
    "resend": "^6.12.2",
    "tsx": "^4.19.0",
    "yjs": "^13.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "dotenv": "^17.4.2",
    "jszip": "^3.10.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
