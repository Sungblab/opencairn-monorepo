{
  "name": "opencairn",
  "private": true,
  "description": "Self-hostable, multi-LLM knowledge OS for individuals and teams.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "node scripts/dev-docker.mjs",
    "dev:host": "node scripts/dev.mjs",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate --filter=@opencairn/db",
    "db:migrate": "turbo db:migrate --filter=@opencairn/db",
    "db:studio": "turbo db:studio --filter=@opencairn/db",
    "docs:check": "node scripts/check-docs-consistency.mjs",
    "canvas:guard": "bash scripts/canvas-regression-guard.sh",
    "dev:docker": "node scripts/dev-docker.mjs",
    "dev:docker:down": "node scripts/dev-docker.mjs --down",
    "dev:docker:logs": "node scripts/dev-docker.mjs --logs",
    "dev:docker:rebuild": "docker compose --profile app --profile worker --profile hocuspocus build --no-cache",
    "dev:docker:reset": "docker compose --profile app --profile worker --profile hocuspocus --profile ollama down -v"
  },
  "devDependencies": {
    "turbo": "^2.9.7",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "dompurify": "^3.4.0",
      "fast-uri": "3.1.2",
      "fast-xml-builder": "^1.1.7",
      "ip-address": "10.1.1",
      "postcss": "^8.5.10",
      "uuid": "14.0.0"
    },
    "neverBuiltDependencies": [
      "canvas"
    ]
  }
}
