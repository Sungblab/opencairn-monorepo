{
  "uid": "canvas-outputs",
  "title": "OpenCairn — Canvas Outputs",
  "tags": ["opencairn", "plan-7", "canvas", "storage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "current": {},
        "refresh": 1,
        "hide": 0
      },
      {
        "name": "bucket",
        "type": "constant",
        "label": "S3 bucket",
        "current": { "value": "opencairn-uploads", "text": "opencairn-uploads" },
        "query": "opencairn-uploads",
        "hide": 2
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "purge runs",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "iconColor": "rgba(255, 96, 96, 1)",
        "expr": "changes(opencairn_canvas_outputs_purge_runs_total[$__interval]) > 0",
        "titleFormat": "purge_canvas_outputs cron tick"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Object count under canvas-outputs/*",
      "description": "Gauge emitted by the worker s3-metrics scrape. Compare to expected (one png/svg per matplotlib turn) — a sustained climb signals orphaning faster than the 30-day cron can sweep.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000 },
              { "color": "red", "value": 200000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "opencairn_canvas_outputs_object_count{bucket=\"$bucket\"}",
          "legendFormat": "objects"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total bytes under canvas-outputs/*",
      "description": "Storage cost watermark. Set the warn/critical thresholds to whatever your hosting plan tolerates (defaults below are for a hobby R2 plan).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5368709120 },
              { "color": "red", "value": 21474836480 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "opencairn_canvas_outputs_total_bytes{bucket=\"$bucket\"}",
          "legendFormat": "bytes"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Upload failure rate (5m)",
      "description": "Ratio of POST /api/canvas/output non-2xx to total. Sustained > 1% usually means MinIO/R2 misconfig (presigned PUT URL host) or outputBadType drift after a Plate plugin upgrade.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(opencairn_canvas_upload_total{status=\"failure\"}[5m])) / clamp_min(sum(rate(opencairn_canvas_upload_total[5m])), 1)",
          "legendFormat": "failure rate"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Object count over time",
      "description": "Look for the saw-tooth: aggressive accumulation between cron runs, sharp drop at each purge_canvas_outputs tick (see the annotation rail above).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "opencairn_canvas_outputs_object_count{bucket=\"$bucket\"}",
          "legendFormat": "objects"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Upload outcomes (req/s)",
      "description": "Stacked counter — green is success, red is failure. Spikes that line up with deploy markers usually mean a regression in the bodyLimit / mime-allow-list path.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "showLegend": true, "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(opencairn_canvas_upload_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
